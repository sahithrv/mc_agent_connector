# DEEPSEEK_API_KEY=replace-with-your-deepseek-key
DEEPSEEK_MODEL=deepseek-chat
MCAS_PLUGIN_SHARED_SECRET=dev-local-secret
MC_AUTO_CONNECT_AGENTS=false
MC_AGENT_SPAWN_TIMEOUT_MS=20000
